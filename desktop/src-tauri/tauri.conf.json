{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoopLens",
  "version": "0.1.2",
  "identifier": "com.looplens.desktop",
  "build": {
    "beforeDevCommand": "npm run build:native && npm run dev:vite",
    "beforeBuildCommand": "npm run build:native && npm run build:vite",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LoopLens",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
